# ─────────────────────────────────────────────────────────────────────────────
# Google Sheets integration (server-side, required for live data sync)
# ─────────────────────────────────────────────────────────────────────────────

# Google service-account email (from your GCP credentials JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# RSA private key from the service-account credentials JSON.
# Paste the full -----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY----- block.
# In .env files use literal \n between lines (no real line breaks).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# The spreadsheet ID — found in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Name of the tab/worksheet inside the spreadsheet (defaults to "Sheet1")
GOOGLE_SHEET_TAB=Sheet1

# ─────────────────────────────────────────────────────────────────────────────
# Polling / sync (client-side, exposed to the browser)
# ─────────────────────────────────────────────────────────────────────────────

# How often (in milliseconds) the dashboard polls the Google Sheet for updates.
# Default: 10000 (10 seconds). Set to 0 to disable polling entirely.
NEXT_PUBLIC_SYNC_INTERVAL_MS=10000
