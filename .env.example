# Google Sheets API Configuration
# Required for automatic data syncing from Google Sheets

# Service account email from the JSON key file (created in Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com

# Private key from the JSON key file (copy the entire key value between quotes)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour/Private/Key/Here\n-----END PRIVATE KEY-----\n"

# Google Sheet ID (the long string in the URL between /d/ and /edit)
GOOGLE_SHEET_ID=your-sheet-id-here

# Sheet tab name (default: Sheet1)
GOOGLE_SHEET_TAB=Sheet1

# Polling interval for syncing data from the sheet (milliseconds, default: 10000 = 10 seconds)
NEXT_PUBLIC_SHEET_SYNC_INTERVAL_MS=10000
